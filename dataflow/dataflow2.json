{
	"name": "dataflow2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "productblobprj5",
						"type": "DatasetReference"
					},
					"name": "srccsvprd"
				},
				{
					"dataset": {
						"referenceName": "productDimtblprj5",
						"type": "DatasetReference"
					},
					"name": "srcproductdim"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "productDimtblprj5",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "productDimtblprj5",
						"type": "DatasetReference"
					},
					"name": "sink2"
				}
			],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "split1"
				},
				{
					"name": "select1"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "alterRow2"
				},
				{
					"name": "dcadditionalcol"
				},
				{
					"name": "alterRow3"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ProductID as string,",
				"          Product as string,",
				"          Price as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> srccsvprd",
				"source(output(",
				"          ProductID as integer,",
				"          Product as string,",
				"          Price as integer,",
				"          StartDate as date,",
				"          EndDate as date,",
				"          IsActive as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcproductdim",
				"derivedColumn1, srcproductdim lookup(derivedColumn1@ProductID == srcproductdim@ProductID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"srccsvprd derive(ProductID = toInteger(ProductID),",
				"          Price = toInteger(Price)) ~> derivedColumn1",
				"select1 split(isNull(ProductID_dim),",
				"     Price_src != Price_dim,",
				"     disjoint: true) ~> split1@(newrecords, updatedRecord, nochange)",
				"lookup1 select(mapColumn(",
				"          ProductID_src = derivedColumn1@ProductID,",
				"          Product_src = srccsvprd@Product,",
				"          Price_src = derivedColumn1@Price,",
				"          ProductID_dim = srcproductdim@ProductID,",
				"          Product_dim = srcproductdim@Product,",
				"          Price_dim = srcproductdim@Price,",
				"          StartDate,",
				"          EndDate,",
				"          IsActive",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"split1@newrecords alterRow(insertIf(true())) ~> alterRow1",
				"dcadditionalcol alterRow(updateIf(true()),",
				"     insertIf(true())) ~> alterRow2",
				"alterRow3 derive(StartDate = currentDate(),",
				"          EndDate = toDate('9999-12-31'),",
				"          IsActive = true()) ~> dcadditionalcol",
				"split1@updatedRecord alterRow(updateIf(true())) ~> alterRow3",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          ProductID as integer,",
				"          Product as string,",
				"          Price as integer,",
				"          StartDate as date,",
				"          EndDate as date,",
				"          IsActive as boolean",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1",
				"alterRow2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          ProductID as integer,",
				"          Product as string,",
				"          Price as integer,",
				"          StartDate as date,",
				"          EndDate as date,",
				"          IsActive as boolean",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          StartDate,",
				"          EndDate,",
				"          IsActive",
				"     )) ~> sink2"
			]
		}
	}
}