{
	"name": "dataflow2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "productblobprj5",
						"type": "DatasetReference"
					},
					"name": "srccsvprd"
				},
				{
					"dataset": {
						"referenceName": "salesADF",
						"type": "DatasetReference"
					},
					"name": "srcproductdim"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "split1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"parameters{",
				"     product_dim as string",
				"}",
				"source(output(",
				"          ProductID as string,",
				"          Product as string,",
				"          Price as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> srccsvprd",
				"source(output(",
				"          OrderID as integer,",
				"          Product as string,",
				"          Amount as integer,",
				"          OrderDate as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcproductdim",
				"derivedColumn1, srcproductdim lookup(ProductID == OrderID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1 split(ERROR_FUNCTION('isNull(srcproductdim.)'),",
				"     srccsvprd@Price != srcproductdim.Amount,",
				"     disjoint: true) ~> split1@(newRecords, UpdatedRecord, nochange)",
				"srccsvprd derive(ProductID = toInteger(ProductID),",
				"          Price = toInteger(Price)) ~> derivedColumn1"
			]
		}
	}
}