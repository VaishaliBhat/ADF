{
	"name": "dataflow2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "productblobprj5",
						"type": "DatasetReference"
					},
					"name": "srccsvprd"
				},
				{
					"dataset": {
						"referenceName": "productDimtblprj5",
						"type": "DatasetReference"
					},
					"name": "srcproductdim"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "productDimtblprj5",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "split1"
				},
				{
					"name": "select1"
				},
				{
					"name": "alterNewrow"
				},
				{
					"name": "alterrowInsert"
				},
				{
					"name": "dcadditionalcol"
				},
				{
					"name": "alterupdate"
				},
				{
					"name": "dcupdate"
				},
				{
					"name": "unionUpdateNewrow"
				},
				{
					"name": "updatecombined"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ProductID as string,",
				"          Product as string,",
				"          Price as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> srccsvprd",
				"source(output(",
				"          ProductID as integer,",
				"          Product as string,",
				"          Price as integer,",
				"          StartDate as date,",
				"          EndDate as date,",
				"          IsActive as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcproductdim",
				"derivedColumn1, srcproductdim lookup(derivedColumn1@ProductID == srcproductdim@ProductID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"srccsvprd derive(ProductID = toInteger(ProductID),",
				"          Price = toInteger(Price)) ~> derivedColumn1",
				"select1 split(isNull(ProductID_dim),",
				"     Price_src != Price_dim,",
				"     disjoint: true) ~> split1@(newrecords, updatedRecord, nochange)",
				"lookup1 select(mapColumn(",
				"          ProductID_src = derivedColumn1@ProductID,",
				"          Product_src = srccsvprd@Product,",
				"          Price_src = derivedColumn1@Price,",
				"          ProductID_dim = srcproductdim@ProductID,",
				"          Product_dim = srcproductdim@Product,",
				"          Price_dim = srcproductdim@Price,",
				"          StartDate,",
				"          EndDate,",
				"          IsActive",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"derivedColumn2 alterRow(insertIf(true())) ~> alterNewrow",
				"dcadditionalcol alterRow(insertIf(true())) ~> alterrowInsert",
				"split1@updatedRecord derive(StartDate = currentTimestamp(),",
				"          EndDate = toTimestamp('9999-12-31'),",
				"          IsActive = true()) ~> dcadditionalcol",
				"dcupdate alterRow(updateIf(true())) ~> alterupdate",
				"split1@updatedRecord derive(EndDate = currentTimestamp(),",
				"          IsActive = false(),",
				"          StartDate = currentTimestamp()) ~> dcupdate",
				"alterupdate, alterNewrow union(byName: true)~> unionUpdateNewrow",
				"unionUpdateNewrow, alterrowInsert union(byName: true)~> updatecombined",
				"split1@newrecords derive(StartDate = currentTimestamp(),",
				"          EndDate = currentTimestamp()) ~> derivedColumn2",
				"updatecombined sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          ProductID as integer,",
				"          Product as string,",
				"          Price as integer,",
				"          StartDate as date,",
				"          EndDate as date,",
				"          IsActive as boolean",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ProductID = ProductID_src,",
				"          Product = Product_src,",
				"          Price = Price_src,",
				"          StartDate,",
				"          EndDate,",
				"          IsActive",
				"     )) ~> sink1"
			]
		}
	}
}